{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/auth/:action", "destination": "/api/auth" },
    { "source": "/api/tutors", "destination": "/api/tutors" },
    { "source": "/api/sessions", "destination": "/api/sessions" },
    { "source": "/api/sessions/:id", "destination": "/api/sessions-id" },
    { "source": "/api/applications", "destination": "/api/applications" },
    { "source": "/api/admin/sync", "destination": "/api/admin/sync" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/((?!api).*)", "destination": "/public/$1" }
  ]
}
